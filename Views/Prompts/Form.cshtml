@using OllamaClient.Models
@model Prompt

@{
    string title = string.IsNullOrEmpty(Model?.Id) ? "Create Prompt" : "Edit Prompt";
    string submitButtonText = string.IsNullOrEmpty(Model?.Id) ? "Create" : "Update";
    string action = string.IsNullOrEmpty(Model?.Id) ? "Create" : "Edit";
    
    ViewData["Title"] = title;
}

<div class="main-header">
    <h1>
        <i class="bi @(string.IsNullOrEmpty(Model?.Id) ? "bi-plus-circle-fill" : "bi-pencil-fill") icon"></i>
        @title
    </h1>
</div>

<div class="row">
    <div class="col-lg-8">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>Please fix the errors below:</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <ul class="mt-2 mb-0">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-pencil-square"></i> Prompt Details
                </h5>
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action(action, "Prompts")">
                    @if (!string.IsNullOrEmpty(Model?.Id))
                    {
                        <input type="hidden" name="Id" value="@Model.Id" />
                    }

                    <div class="mb-4">
                        <label for="Name" class="form-label">
                            <i class="bi bi-bookmark-fill"></i> Prompt Name
                            <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control form-control-lg" id="Name" name="Name" 
                               placeholder="Quest Generator, Dialog Writer, etc."
                               value="@Model?.Name" required />
                        <small class="form-text text-muted d-block mt-2">A clear, descriptive name for this prompt</small>
                    </div>

                    <div class="mb-4">
                        <label for="Content" class="form-label">
                            <i class="bi bi-chat-dots-fill"></i> Prompt Content
                            <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" id="Content" name="Content" 
                                  rows="18" placeholder="Enter your prompt here..."
                                  required>@Model?.Content</textarea>
                        <small class="form-text text-muted d-block mt-2">The complete prompt that will be sent to Ollama</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle-fill"></i> @submitButtonText Prompt
                        </button>
                        <a href="@Url.Action("Index", "Prompts")" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-lightbulb-fill"></i> Best Practices
                </h5>
            </div>
            <div class="card-body small">
                <ul class="mb-0">
                    <li><strong>Be specific:</strong> Clear instructions lead to better results</li>
                    <li><strong>Add context:</strong> Provide relevant background information</li>
                    <li><strong>Include examples:</strong> Show the format you want</li>
                    <li><strong>Use structure:</strong> Section headers make prompts clearer</li>
                    <li><strong>Test thoroughly:</strong> Refine based on results</li>
                </ul>
            </div>
        </div>

        @if (Model != null && !string.IsNullOrEmpty(Model.Id))
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-info-circle"></i> Metadata
                    </h5>
                </div>
                <div class="card-body small">
                    <div class="mb-3">
                        <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="bi bi-calendar2"></i> Created
                        </h6>
                        <p class="mb-0">@Model.CreatedAt.ToString("dddd, MMMM d, yyyy h:mm tt")</p>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="bi bi-clock-history"></i> Last Updated
                        </h6>
                        <p class="mb-0">@Model.UpdatedAt.ToString("dddd, MMMM d, yyyy h:mm tt")</p>
                    </div>
                    <hr>
                    <div>
                        <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="bi bi-key-fill"></i> ID
                        </h6>
                        <code class="small" title="@Model.Id">@Model.Id.Substring(0, 8)...</code>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
