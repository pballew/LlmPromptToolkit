@using OllamaClient.Models
@model List<Prompt>

@{
    ViewData["Title"] = "Manage Prompts";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h1>Prompts</h1>
        </div>
        <div class="col text-end">
            <a href="@Url.Action("Create", "Prompts")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Prompt
            </a>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Created</th>
                        <th>Updated</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prompt in Model)
                    {
                        <tr>
                            <td>
                                <strong>@prompt.Name</strong>
                            </td>
                            <td>
                                <small class="text-muted">@prompt.CreatedAt.ToString("g")</small>
                            </td>
                            <td>
                                <small class="text-muted">@prompt.UpdatedAt.ToString("g")</small>
                            </td>
                            <td class="text-end">
                                <a href="@Url.Action("Edit", "Prompts", new { id = prompt.Id })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="@Url.Action("Delete", "Prompts", new { id = prompt.Id })" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                                <button class="btn btn-sm btn-info use-prompt-btn" data-prompt-id="@prompt.Id" title="Load this prompt into the builder">
                                    <i class="bi bi-arrow-down-circle"></i> Use
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>No prompts yet. <a href="@Url.Action("Create", "Prompts")" class="alert-link">Create your first prompt</a></p>
        </div>
    }
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Handle "Use Prompt" button clicks
    document.querySelectorAll('.use-prompt-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
            const promptId = this.getAttribute('data-prompt-id');
            try {
                const response = await fetch(`/Prompts/GetPrompt?id=${promptId}`);
                const prompt = await response.json();
                
                // Send to home page or store in session
                // For now, redirect to home with prompt content
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("Index", "Home")';
                
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'prompt';
                input.value = prompt.content;
                
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            } catch (error) {
                alert('Error loading prompt: ' + error);
            }
        });
    });
});
</script>
