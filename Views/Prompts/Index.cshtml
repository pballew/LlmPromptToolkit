@using OllamaClient.Models
@model List<Prompt>

@{
    ViewData["Title"] = "Manage Prompts";
}

<div class="main-header">
    <h1><i class="bi bi-chat-dots-fill icon"></i> Prompts</h1>
</div>

<div class="row mb-4">
    <div class="col">
        <p class="text-muted">
            <i class="bi bi-info-circle"></i> Organize and manage your prompt templates for quick access
        </p>
    </div>
    <div class="col text-end">
        <a href="@Url.Action("Create", "Prompts")" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle-fill"></i> New Prompt
        </a>
    </div>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 40%;">
                        <i class="bi bi-bookmark-fill"></i> Name
                    </th>
                    <th style="width: 20%;">
                        <i class="bi bi-calendar-event"></i> Created
                    </th>
                    <th style="width: 20%;">
                        <i class="bi bi-clock-history"></i> Updated
                    </th>
                    <th style="width: 20%;" class="text-end">
                        <i class="bi bi-gear"></i> Actions
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prompt in Model)
                {
                    <tr class="border-bottom">
                        <td>
                            <div>
                                <strong class="text-dark">@prompt.Name</strong>
                                <br>
                                <small class="text-muted">@prompt.Content.Substring(0, Math.Min(60, prompt.Content.Length)).Replace("\n", " ")...</small>
                            </div>
                        </td>
                        <td>
                            <small class="text-muted">
                                <i class="bi bi-calendar2"></i> @prompt.CreatedAt.ToString("MMM d, yyyy")
                            </small>
                        </td>
                        <td>
                            <small class="text-muted">
                                <i class="bi bi-calendar2-check"></i> @prompt.UpdatedAt.ToString("MMM d, yyyy")
                            </small>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="@Url.Action("Edit", "Prompts", new { id = prompt.Id })" class="btn btn-outline-warning" title="Edit prompt">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-outline-info use-prompt-btn" data-prompt-id="@prompt.Id" title="Load into builder">
                                    <i class="bi bi-arrow-down-circle"></i>
                                </button>
                                <a href="@Url.Action("Delete", "Prompts", new { id = prompt.Id })" class="btn btn-outline-danger" title="Delete prompt">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card border-info">
        <div class="card-body text-center py-5">
            <div style="font-size: 3rem; color: #6366f1; margin-bottom: 1rem;">
                <i class="bi bi-inbox"></i>
            </div>
            <h4 class="card-title">No Prompts Yet</h4>
            <p class="text-muted mb-3">Create your first prompt to get started. Prompts are templates you can reuse to make requests faster.</p>
            <a href="@Url.Action("Create", "Prompts")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create Your First Prompt
            </a>
        </div>
    </div>
}

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.use-prompt-btn').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            const promptId = this.getAttribute('data-prompt-id');
            try {
                const response = await fetch(`/Prompts/GetPrompt?id=${promptId}`);
                const prompt = await response.json();
                
                // Create and submit form
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("SendRequest", "Home")';
                
                const promptInput = document.createElement('input');
                promptInput.type = 'hidden';
                promptInput.name = 'prompt';
                promptInput.value = prompt.content;
                
                form.appendChild(promptInput);
                document.body.appendChild(form);
                
                // Show feedback
                const originalHTML = this.innerHTML;
                this.innerHTML = '<i class="bi bi-check-circle-fill"></i>';
                
                setTimeout(() => form.submit(), 300);
            } catch (error) {
                alert('Error loading prompt: ' + error);
            }
        });
    });
});
</script>
