@using OllamaClient.Models
@model Prompt

@{
    ViewData["Title"] = "Delete Prompt";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="card-title mb-0">Delete Prompt?</h4>
                </div>
                <div class="card-body">
                    <p class="mb-3">Are you sure you want to delete this prompt? This action cannot be undone.</p>

                    <div class="alert alert-light border">
                        <p class="mb-1"><strong>Name:</strong> @Model.Name</p>
                        <p class="mb-1"><strong>Created:</strong> @Model.CreatedAt.ToString("g")</p>
                        <p class="mb-0"><strong>Content:</strong></p>
                        <pre class="mt-2 mb-0" style="max-height: 200px; overflow-y: auto; background-color: #f8f9fa; padding: 10px; border-radius: 4px;">@Model.Content</pre>
                    </div>

                    <form method="post" action="@Url.Action("DeleteConfirm", "Prompts")" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Yes, Delete This Prompt
                        </button>
                        <a href="@Url.Action("Index", "Prompts")" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
