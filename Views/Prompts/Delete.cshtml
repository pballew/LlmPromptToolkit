@using LlmPromptToolkit.Models
@model Prompt

@{
    ViewData["Title"] = "Delete Prompt";
}

<div class="main-header">
    <h1><i class="bi bi-trash-fill icon text-danger"></i> Delete Prompt</h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Are you sure?
                </h5>
            </div>
            <div class="card-body">
                <p class="mb-4">Deleting this prompt is permanent and cannot be undone. Please review the prompt details below before confirming.</p>

                <div class="alert alert-light border-start border-danger border-4 mb-4">
                    <div class="mb-3">
                        <h6 class="fw-bold text-dark mb-2">
                            <i class="bi bi-bookmark-fill"></i> @Model.Name
                        </h6>
                        <small class="text-muted">
                            <i class="bi bi-calendar2"></i> Created @Model.CreatedAt.ToString("MMM d, yyyy")
                        </small>
                    </div>
                    <hr>
                    <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.5px;">Content Preview:</h6>
                    <pre class="mb-0" style="max-height: 250px; overflow-y: auto; background-color: #f9fafb; padding: 12px; border-radius: 4px; font-size: 0.875rem; white-space: pre-wrap; word-wrap: break-word;">@Model.Content</pre>
                </div>

                <form method="post" action="@Url.Action("DeleteConfirm", "Prompts")" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-lg flex-grow-1">
                            <i class="bi bi-trash-fill"></i> Yes, Delete This Prompt
                        </button>
                        <a href="@Url.Action("Index", "Prompts")" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-info-circle"></i> What Happens?
                </h5>
            </div>
            <div class="card-body small">
                <div class="mb-4">
                    <h6 class="fw-bold text-danger mb-2">
                        <i class="bi bi-x-circle-fill"></i> This Action Will:
                    </h6>
                    <ul class="mb-0">
                        <li>Remove this prompt from your library</li>
                        <li>Delete the prompt file from storage</li>
                        <li>Make it unavailable in the prompt selector</li>
                    </ul>
                </div>

                <div class="alert alert-warning mb-0">
                    <i class="bi bi-lightbulb-fill"></i>
                    <p class="mb-0"><strong>Tip:</strong> If you might need this prompt later, consider editing it instead of deleting it.</p>
                </div>
            </div>
        </div>
    </div>
</div>
