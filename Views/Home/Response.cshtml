@model RequestResponseViewModel

@{
    ViewData["Title"] = "Response";
}

<div class="main-header">
    <h1><i class="bi bi-chat-left-text-fill icon"></i> Response</h1>
</div>

<div class="row">
    <div class="col-lg-9">
        <!-- Request Details -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="bi bi-pencil-square"></i> Your Prompt
                </h5>
            </div>
            <div class="card-body">
                <pre class="bg-light p-3 rounded" style="border-left: 4px solid #6366f1; margin: 0; white-space: pre-wrap; word-wrap: break-word;">@Model.Prompt</pre>
            </div>
        </div>

        <!-- Timing & Metrics -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card metric-card">
                    <div class="card-body">
                        <div class="metric-label">
                            <i class="bi bi-hourglass-split"></i> Response Time
                        </div>
                        <div class="metric-value">
                            @Model.TimingMs<span class="metric-unit">ms</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card metric-card">
                    <div class="card-body">
                        <div class="metric-label">
                            <i class="bi bi-coin"></i> Context Tokens
                        </div>
                        <div class="metric-value">
                            @Model.TokenCount<span class="metric-unit">tokens</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Validation Results -->
        @await Html.PartialAsync("_ValidationResultsPanel", Model.ValidationResult)

        <!-- Response Content -->
        <div class="card response-card mb-4">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-chat-dots-fill"></i> Response
                    </h5>
                    <small class="text-muted">
                        <i class="bi bi-calendar-event"></i> @Model.CreatedAt.ToString("g")
                    </small>
                </div>
            </div>
            <div class="card-body">
                <p class="mb-3">
                    <span class="badge badge-primary">
                        <i class="bi bi-robot"></i> @Model.Model
                    </span>
                </p>
                <div class="bg-white p-4 border rounded" style="border-left: 4px solid #10b981;">
                    <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; font-family: 'Monaco', 'Courier New', monospace; font-size: 0.95rem;">@Model.Response</pre>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2 justify-content-between">
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> New Request
            </a>
            <button class="btn btn-primary btn-lg" onclick="copyToClipboard()">
                <i class="bi bi-clipboard"></i> Copy Response
            </button>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="bi bi-info-circle"></i> Details
                </h5>
            </div>
            <div class="card-body small">
                <div class="mb-3">
                    <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <i class="bi bi-robot"></i> Model
                    </h6>
                    <p class="mb-0">@Model.Model</p>
                </div>
                <hr>
                <div class="mb-3">
                    <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <i class="bi bi-hourglass-split"></i> Timing
                    </h6>
                    <p class="mb-0">@Model.TimingMs ms</p>
                </div>
                <hr>
                <div>
                    <h6 class="fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <i class="bi bi-coin"></i> Tokens
                    </h6>
                    <p class="mb-0">@Model.TokenCount tokens</p>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="bi bi-lightning-charge"></i> Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-plus-circle"></i> New Request
                    </a>
                    <a href="@Url.Action("Index", "Prompts")" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-bookmark"></i> Save as Prompt
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function copyToClipboard() {
        const responseText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Response));
        navigator.clipboard.writeText(responseText).then(() => {
            // Show success feedback
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Copied!';
            btn.classList.add('btn-success');
            btn.classList.remove('btn-primary');
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-primary');
            }, 2000);
        }).catch(err => {
            alert('Could not copy text: ' + err);
        });
    }
</script>
