@using LlmPromptToolkit.Models
@model HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="main-header">
    <h1><i class="bi bi-house-fill icon"></i> Home</h1>
</div>

<div class="container">
    <div class="row">
        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <strong>Error:</strong> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="bi bi-pencil-square"></i> Manage Your Prompts
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model?.AvailablePrompts != null && Model.AvailablePrompts.Count > 0)
                    {
                        <p class="mb-3">You have <strong>@Model.AvailablePrompts.Count</strong> saved prompt(s).</p>
                        <div class="list-group">
                            @foreach (var p in Model.AvailablePrompts)
                            {
                                <a href="@Url.Action("Edit", "Prompts", new { id = p.Id })" class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1"><i class="bi bi-bookmark-fill"></i> @p.Name</h6>
                                        <small class="text-muted">@p.UpdatedAt.ToString("MMM d, yyyy")</small>
                                    </div>
                                    <p class="mb-1 text-truncate">@p.Content</p>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-lightbulb-fill"></i>
                            <p class="mb-1"><strong>No saved prompts yet.</strong> <a
                                href="@Url.Action("Create", "Prompts")" class="alert-link">Create one now</a> to get started.</p>
                        </div>
                    }

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end gap-3 mt-4">
                        <a href="@Url.Action("Create", "Prompts")" class="btn btn-primary btn-lg">
                            <i class="bi bi-plus-circle-fill"></i> Create New Prompt
                        </a>
                        <a href="@Url.Action("Comms", "Home")" class="btn btn-success btn-lg">
                            <i class="bi bi-chat-dots-fill"></i> Go to Communications
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4 sticky-lg-top" style="top: 80px;">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="bi bi-info-circle"></i> Quick Start
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="fw-bold text-primary">
                            <i class="bi bi-star-fill"></i> Getting Started
                        </h6>
                        <ul class="small mb-0">
                            <li><a href="@Url.Action("Create", "Prompts")">Create a new prompt</a></li>
                            <li><a href="@Url.Action("Comms", "Home")">Go to Communications</a> to send prompts</li>
                            <li>View your prompt history</li>
                            <li>Monitor the communication log</li>
                        </ul>
                    </div>
                    <hr>
                    <div>
                        <h6 class="fw-bold text-success">
                            <i class="bi bi-lightning-charge"></i> Quick Actions
                        </h6>
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Create", "Prompts")" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-plus-circle"></i> New Prompt
                            </a>
                            <a href="@Url.Action("Comms", "Home")" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-chat-dots-fill"></i> Communications
                            </a>
                            <a href="@Url.Action("Index", "Prompts")" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-collection"></i> Manage Prompts
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="bi bi-gear"></i> Settings
                    </h5>
                </div>
                <div class="card-body small">
                    <p class="mb-2">
                        <strong>Model:</strong><br>
                        <span class="badge badge-primary">glm-5:cloud</span>
                    </p>
                    <p class="mb-0">
                        <strong>Endpoint:</strong><br>
                        <code class="small">localhost:11434</code>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
