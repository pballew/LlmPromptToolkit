@using OllamaClient.Models
@model HomeIndexViewModel

@{
    ViewData["Title"] = "Request Builder";
}

<div class="row mt-4">
    <div class="col-md-8 offset-md-2">
        <h1 class="mb-4">Build Request</h1>

        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="post" action="@Url.Action("SendRequest", "Home")">
            @if (Model?.AvailablePrompts != null && Model.AvailablePrompts.Count > 0)
            {
                <div class="mb-3">
                    <label for="selectedPromptId" class="form-label">Select a Saved Prompt</label>
                    <div class="input-group">
                        <select class="form-select" id="selectedPromptId" name="selectedPromptId" onchange="loadPromptContent()">
                            <option value="">-- Choose a prompt --</option>
                            @foreach (var p in Model.AvailablePrompts)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <a href="@Url.Action("Index", "Prompts")" class="btn btn-outline-secondary" title="Manage prompts">
                            <i class="bi bi-gear"></i> Manage
                        </a>
                    </div>
                    <small class="form-text text-muted">Or create a new prompt in the manager</small>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-3">
                    <p class="mb-1">No saved prompts yet. <a href="@Url.Action("Create", "Prompts")" class="alert-link">Create one now</a></p>
                </div>
            }

            <div class="mb-3">
                <label for="prompt" class="form-label">Enter Your Prompt</label>
                <textarea 
                    class="form-control form-control-lg" 
                    id="prompt" 
                    name="prompt" 
                    rows="8" 
                    placeholder="Enter your prompt here..." 
                    required>@Model?.Prompt</textarea>
                <small class="form-text text-muted">Paste prompt text or select from your saved prompts above</small>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <button type="reset" class="btn btn-secondary btn-lg">Clear</button>
                <button type="submit" class="btn btn-primary btn-lg">Send Request</button>
            </div>
        </form>
    </div>
</div>

<script>
async function loadPromptContent() {
    const select = document.getElementById('selectedPromptId');
    const promptTextarea = document.getElementById('prompt');
    const promptId = select.value;

    if (!promptId) {
        return; // No prompt selected
    }

    try {
        const response = await fetch(`/Prompts/GetPrompt?id=${promptId}`);
        const prompt = await response.json();
        if (prompt && prompt.content) {
            promptTextarea.value = prompt.content;
        }
    } catch (error) {
        alert('Error loading prompt: ' + error);
    }
}
</script>

