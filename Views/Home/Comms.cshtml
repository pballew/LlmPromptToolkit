@using LlmPromptToolkit.Models
@model CommsViewModel

@{
    ViewData["Title"] = "Comms";
}

<div class="main-header">
    <h1><i class="bi bi-chat-dots-fill icon"></i> Communications</h1>
</div>

<div class="container-fluid" style="position: relative; height: calc(100vh - 120px);">
    <div style="height: 100%; margin-right: calc(33.333% + 30px);">
        <!-- Conversation Area -->
        <div style="display: flex; flex-direction: column; height: 100%; padding: 15px;">
            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <strong>Error:</strong> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Active Schema Indicator -->
            <div id="activeSchemaPanel" style="display: none; margin-bottom: 5px; background-color: #e7f3ff; border: 1px solid #b3d9ff; border-radius: 6px;" class="d-flex align-items-center justify-content-between">
                <div>
                    <small class="d-block text-muted mb-1">
                        <i class="bi bi-shield-lock"></i> Schema validation enabled
                    </small>
                    <small id="schemaSourceText" class="d-block"></small>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="disableValidation()" title="Remove active schema">
                    <i class="bi bi-x-circle"></i> Disable
                </button>
            </div>

            <!-- Conversation History Container -->
            <div id="conversationHistory" class="p-1" style="flex: 1; overflow-y: auto; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 5px; background-color: #f9f9f9;">
                <!-- Conversation items will be added here dynamically -->
            </div>

            <!-- Prompt Input Section -->
            <div class="card">
                <div class="card-body p-1">
                    <!-- Model Selection -->
                    <div class="mb-1">
                        <label for="modelDropdown" class="form-label">
                            <i class="bi bi-router"></i> AI Model
                        </label>
                        <div class="input-group input-group-sm">
                            <select class="form-select" id="modelDropdown" 
                                    onchange="switchModel()" style="max-width: 100%;">
                                <option value="local" selected>Local Model (llama3.1:8b - Default)</option>
                                <option value="cloud">Cloud Model (glm-5:cloud)</option>
                            </select>
                            <span class="input-group-text" id="modelStatus">
                                <small><span class="badge bg-success">✓ Ready</span></span>
                            </span>
                        </div>
                    </div>

                    @if (Model?.AvailablePrompts != null && Model.AvailablePrompts.Count > 0)
                    {
                        <div class="mb-1">
                            <label for="promptDropdown" class="form-label">
                                <i class="bi bi-bookmark-fill"></i> Select a Prompt
                            </label>
                            <div class="input-group input-group-sm">
                                <select class="form-select" id="promptDropdown" 
                                        onchange="loadPrompt()" style="max-width: 100%;">
                                    <option value="">-- Choose a prompt --</option>
                                    @foreach (var p in Model.AvailablePrompts)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                                <a href="@Url.Action("Index", "Prompts")" class="btn btn-outline-secondary"
                                    title="Manage saved prompts">
                                    <i class="bi bi-gear"></i> Manage
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-1">
                            <i class="bi bi-lightbulb-fill"></i>
                            <p class="mb-1"><strong>No saved prompts yet.</strong> <a
                                href="@Url.Action("Create", "Prompts")" class="alert-link">Create one now</a></p>
                        </div>
                    }

                    <div class="mb-1">
                        <label for="promptTextarea" class="form-label">
                            <i class="bi bi-chat-dots-fill"></i> Prompt
                        </label>
                        <textarea class="form-control" id="promptTextarea" 
                                  placeholder="Select a prompt from the dropdown above or enter your own"
                                  style="min-height: 100px; width: 100%;"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-primary" id="sendBtn" onclick="sendPrompt()">
                            <i class="bi bi-send-fill"></i> Send
                        </button>
                        <button type="button" class="btn btn-secondary" id="clearBtn" onclick="clearPrompt()">
                            <i class="bi bi-arrow-clockwise"></i> Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

<partial name="_LogWindow" />

<script>
    let conversationHistory = [];
    let isSending = false;
    let activeSchema = null;
    let activeSchemaSourceIndex = null;

    // Switch between local and cloud models
    async function switchModel() {
        const modelType = document.getElementById('modelDropdown').value;
        const statusElement = document.getElementById('modelStatus');
        
        try {
            statusElement.innerHTML = '<small><span class="badge bg-warning">Loading...</span></small>';
            
            const formData = new FormData();
            formData.append('modelType', modelType);
            
            const response = await fetch('/Home/SetModel', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            if (result.success) {
                // Clear conversation history
                conversationHistory = [];
                document.getElementById('conversationHistory').innerHTML = '';
                
                // Update status badge
                if (result.available) {
                    statusElement.innerHTML = '<small><span class="badge bg-success">✓ Ready</span></small>';
                } else {
                    statusElement.innerHTML = '<small><span class="badge bg-warning">⚠ Loading</span></small>';
                }
                
                console.log('Model switched to:', result.modelName);
                console.log('Message:', result.message);
            } else {
                statusElement.innerHTML = '<small><span class="badge bg-danger">✗ Error</span></small>';
                alert('Error switching model: ' + result.error);
            }
        } catch (error) {
            console.error('Error switching model:', error);
            statusElement.innerHTML = '<small><span class="badge bg-danger">✗ Error</span></small>';
            alert('Error switching model');
        }
    }

    // Load prompt when selected
    async function loadPrompt() {
        const promptId = document.getElementById('promptDropdown').value;
        if (!promptId) return;

        try {
            const response = await fetch(`/Prompts/GetPrompt?id=${promptId}`);
            const prompt = await response.json();
            if (prompt && prompt.content) {
                document.getElementById('promptTextarea').value = prompt.content;
                document.getElementById('promptTextarea').focus();
            }
        } catch (error) {
            console.error('Error loading prompt:', error);
            alert('Error loading prompt');
        }
    }

    // Extract JSON from response text
    function extractJsonFromResponse(text) {
        console.log('extractJsonFromResponse called with text length:', text.length);
        
        // Try pattern: json: ``` {...} ```
        const jsonPrefixMatch = text.match(/json:\s*```\s*([\s\S]*?)```/);
        if (jsonPrefixMatch && jsonPrefixMatch[1]) {
            console.log('Matched json: prefix pattern');
            try {
                const result = JSON.parse(jsonPrefixMatch[1].trim());
                console.log('Successfully parsed json: pattern');
                return result;
            } catch (e) {
                console.log('Failed to parse json: pattern:', e.message);
                // Fall through to next pattern
            }
        }
        
        // Try pattern: ```json {...} ``` or ``` {...} ```
        const jsonMatch = text.match(/```(?:json)?\s*([\s\S]*?)```/);
        console.log('Trying standard pattern, match:', jsonMatch ? 'found' : 'not found');
        if (jsonMatch && jsonMatch[1]) {
            console.log('Matched standard pattern');
            let jsonText = jsonMatch[1].trim();
            
            // Try parsing as-is first
            try {
                const result = JSON.parse(jsonText);
                console.log('Successfully parsed standard pattern');
                return result;
            } catch (e) {
                console.log('Failed to parse as JSON, trying to fix schema template format:', e.message);
                
                // Try to fix common JSON Schema template format issues
                // Replace unquoted type keywords: string, number, boolean, etc.
                jsonText = jsonText.replace(/:\s*(string|number|boolean|object|array|null)\b/g, ': "$1"');
                
                try {
                    const result = JSON.parse(jsonText);
                    console.log('Successfully parsed after fixing template format');
                    return result;
                } catch (e2) {
                    console.log('Failed after fixing format:', e2.message);
                    return null;
                }
            }
        }
        
        // Try parsing entire response as JSON
        try {
            const result = JSON.parse(text);
            console.log('Successfully parsed entire text as JSON');
            return result;
        } catch (e) {
            console.log('Could not extract JSON from text');
            return null;
        }
    }

    // Use schema from a prompt
    function useSchemaFromPrompt(index) {
        console.log('useSchemaFromPrompt called with index:', index);
        const promptText = conversationHistory[index].prompt;
        const jsonData = extractJsonFromResponse(promptText);
        
        if (!jsonData) {
            alert('Could not extract JSON schema from this prompt');
            return;
        }
        
        activeSchema = JSON.stringify(jsonData);
        activeSchemaSourceIndex = index;
        console.log('activeSchema set:', activeSchema.substring(0, 50) + '...');
        
        document.getElementById('schemaSourceText').textContent = 
            `Validating against: "${promptText.substring(0, 60)}${promptText.length > 60 ? '...' : ''}"`;
        
        const panel = document.getElementById('activeSchemaPanel');
        console.log('panel before setting display:', panel.style.display);
        panel.style.display = 'flex';
        console.log('panel after setting display:', panel.style.display);
        
        // Re-validate all responses
        displayConversation();
    }

    // Disable validation
    function disableValidation() {
        console.log('disableValidation called');
        activeSchema = null;
        activeSchemaSourceIndex = null;
        const panel = document.getElementById('activeSchemaPanel');
        console.log('panel element:', panel);
        panel.style.display = 'none';
        console.log('panel hidden, calling displayConversation');
        displayConversation();
        console.log('displayConversation complete');
    }

    // Send prompt
    async function sendPrompt() {
        const promptText = document.getElementById('promptTextarea').value.trim();
        
        if (!promptText) {
            alert('Please enter a prompt');
            return;
        }

        if (isSending) return;
        isSending = true;
        
        const sendBtn = document.getElementById('sendBtn');
        const originalText = sendBtn.innerHTML;
        sendBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Sending...';
        sendBtn.disabled = true;

        try {
            // Add request to conversation history immediately (before sending)
            const newRequestIndex = conversationHistory.length;
            const promptJson = extractJsonFromResponse(promptText);
            const lastContext = conversationHistory.length > 0 
                ? conversationHistory[conversationHistory.length - 1].context 
                : null;
            const contextCountRequest = lastContext ? lastContext.length : 0;
            conversationHistory.push({
                prompt: promptText,
                response: '', // Will be filled in when response arrives
                timing_ms: 0,
                context: null,
                contextCountRequest: contextCountRequest,
                contextCountResponse: 0,
                isLoading: true,
                isSchemaValid: null,
                validationErrors: [],
                promptContainsJson: promptJson !== null,
                responseContainsJson: false
            });

            // Update UI to show the prompt immediately
            displayConversation();
            document.getElementById('promptTextarea').value = '';
            
            // Auto-scroll to bottom
            setTimeout(() => {
                const historyContainer = document.getElementById('conversationHistory');
                historyContainer.scrollTop = historyContainer.scrollHeight;
            }, 100);

            const startTime = Date.now();
            
            const requestBody = { 
                prompt: promptText 
            };
            
            // Include context if available
            if (lastContext && lastContext.length > 0) {
                requestBody.context = lastContext;
            }
            
            // Include schema if active
            if (activeSchema) {
                requestBody.schema = activeSchema;
            }
            
            const response = await fetch('/Home/SendCommsRequest', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(requestBody)
            });

            const endTime = Date.now();
            const timing = endTime - startTime;

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Failed to send prompt');
            }

            const data = await response.json();
            
            // Check if response contains JSON
            const jsonData = extractJsonFromResponse(data.response);
            
            // Update the request with the response
            conversationHistory[newRequestIndex].response = data.response;
            conversationHistory[newRequestIndex].timing_ms = timing;
            conversationHistory[newRequestIndex].context = data.context;
            conversationHistory[newRequestIndex].contextCountResponse = data.contextCount || 0;
            conversationHistory[newRequestIndex].isLoading = false;
            conversationHistory[newRequestIndex].responseContainsJson = jsonData !== null;
            conversationHistory[newRequestIndex].isSchemaValid = data.isSchemaValid;
            conversationHistory[newRequestIndex].validationErrors = data.validationErrors || [];

            // Update UI with the response
            displayConversation();
            
            // Auto-scroll to bottom
            setTimeout(() => {
                const historyContainer = document.getElementById('conversationHistory');
                historyContainer.scrollTop = historyContainer.scrollHeight;
            }, 100);

        } catch (error) {
            console.error('Error:', error);
            alert(`Error: ${error.message}`);
        } finally {
            sendBtn.innerHTML = originalText;
            sendBtn.disabled = false;
            isSending = false;
        }
    }

    // Display conversation
    function displayConversation() {
        const container = document.getElementById('conversationHistory');
        container.innerHTML = '';

        conversationHistory.forEach((item, index) => {
            // Prompt bubble
            const promptDiv = document.createElement('div');
            promptDiv.className = 'mb-3';
            
            let schemaButton = '';
            if (item.promptContainsJson && !activeSchema) {
                schemaButton = `<div class="mt-2 alert alert-info py-2 px-3 mb-0"><small><i class="bi bi-gear"></i> <button type="button" class="btn btn-link btn-sm" onclick="useSchemaFromPrompt(${index})">Use this JSON as schema</button> for validating responses</small></div>`;
            }
            
            promptDiv.innerHTML = `
                <div class="bg-primary text-white rounded p-3" style="margin-left: 20%; word-wrap: break-word;">
                    <small class="d-block mb-2" style="opacity: 0.8;">You${item.contextCountRequest > 0 ? ` (Context: ${item.contextCountRequest} tokens)` : ''}</small>
                    <div>${escapeHtml(item.prompt)}</div>
                    ${schemaButton}
                </div>
            `;
            container.appendChild(promptDiv);

            // Response bubble
            const responseDiv = document.createElement('div');
            responseDiv.className = 'mb-3';
            
            if (item.isLoading) {
                responseDiv.innerHTML = `
                    <div class="bg-light rounded p-3" style="margin-right: 20%; border: 1px solid #ddd;">
                        <small class="d-block mb-2 text-muted">
                            <i class="bi bi-robot"></i> Assistant
                        </small>
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                `;
            } else {
                let validationBadge = '';
                if (activeSchema && item.isSchemaValid !== null) {
                    if (item.isSchemaValid) {
                        validationBadge = '<span class="badge bg-success ms-2"><i class="bi bi-check-circle-fill"></i> Valid</span>';
                    } else {
                        validationBadge = `<span class="badge bg-danger ms-2" data-bs-toggle="tooltip" data-bs-placement="top" title="${escapeHtml(item.validationErrors.join('; '))}"><i class="bi bi-exclamation-circle-fill"></i> Invalid</span>`;
                    }
                }

                responseDiv.innerHTML = `
                    <div class="bg-light rounded p-3" style="margin-right: 20%; border: 1px solid #ddd; word-wrap: break-word;">
                        <div class="d-flex align-items-center mb-2">
                            <small class="text-muted">
                                <i class="bi bi-robot"></i> Assistant (${item.timing_ms}ms${item.contextCountResponse > 0 ? `, Context: ${item.contextCountResponse} tokens` : ''})
                            </small>
                            ${validationBadge}
                        </div>
                        <div>${escapeHtml(item.response)}</div>
                    </div>
                `;
            }
            container.appendChild(responseDiv);
        });
        
        // Re-initialize tooltips
        const tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltips.forEach(t => new bootstrap.Tooltip(t));
    }

    // Clear prompt
    function clearPrompt() {
        document.getElementById('promptTextarea').value = '';
        document.getElementById('promptDropdown').value = '';
    }

    // Escape HTML special characters
    function escapeHtml(text) {
        text = text || '';
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, m => map[m]);
    }
</script>

<style>
    .log-entry {
        padding: 8px;
        margin-bottom: 8px;
        border-left: 3px solid #ddd;
        background-color: #f9f9f9;
        font-size: 0.85rem;
    }

    .log-entry.DEBUG {
        border-left-color: #6c757d;
    }

    .log-entry.INFO {
        border-left-color: #0d6efd;
    }

    .log-entry.WARN {
        border-left-color: #ffc107;
    }

    .log-entry.ERROR {
        border-left-color: #dc3545;
    }

    .log-entry.SUCCESS {
        border-left-color: #198754;
    }

    .log-timestamp {
        color: #999;
        font-size: 0.75rem;
        margin-right: 8px;
    }

    .log-level {
        font-weight: bold;
        font-size: 0.75rem;
        margin-right: 8px;
        text-transform: uppercase;
    }

    .log-message {
        word-break: break-word;
    }
</style>
