<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ollama Client</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUarbnLutan7V7McqwrlWQvrvayLesqA6Yty51rO5h5Z9QwIVN" crossorigin="anonymous">
    <style>
        body { padding-top: 60px; }
        .navbar { background-color: #2c3e50; }
        .container-main { max-width: 1200px; }
        .response-card { background-color: #f8f9fa; border-left: 4px solid #007bff; }
        .timing-badge { margin-right: 10px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark fixed-top">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">Ollama Client</span>
        </div>
    </nav>

    <div class="container container-main">
        @if (!string.IsNullOrEmpty((ViewData["Message"] as string)))
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @ViewData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="text-center text-muted py-4 mt-5">
        <div class="container">
            <small>&copy; 2026 Ollama Client | Connected to Ollama</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWbSxccPQtF3EpF3fnucShowvDi7RfxxZKJlFBe7X6sCwrQ6O" crossorigin="anonymous"></script>
</body>
</html>
