@model ValidationResult

@if (Model != null)
{
    <div class="card mb-4">
        <div class="card-header" style="background-color: @(Model.IsValid ? "var(--success-color)" : "var(--danger-color)");">
            <div class="d-flex align-items-center" style="color: white; font-weight: 600;">
                <i class="bi @(Model.IsValid ? "bi-check-circle-fill" : "bi-exclamation-circle-fill")" style="margin-right: 0.5rem;"></i>
                Validation Result: @(Model.IsValid ? "Valid" : "Invalid")
            </div>
        </div>
        <div class="card-body">
            @if (!Model.IsValid && !string.IsNullOrEmpty(Model.ParseError))
            {
                <div class="alert alert-danger mb-3" role="alert">
                    <strong>Parse Error:</strong> @Model.ParseError
                </div>
            }

            @if (Model.Errors.Any())
            {
                <div class="alert alert-warning mb-3" role="alert">
                    <strong>Validation Issues:</strong>
                    <ul class="mb-0" style="margin-top: 0.5rem;">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.RequiredFieldsStatus.Any())
            {
                <div class="mb-3">
                    <h6 style="color: var(--primary-color); font-weight: 600; margin-bottom: 1rem;">
                        Required Fields (@Model.PopulatedRequiredFields/@Model.TotalRequiredFields)
                    </h6>
                    <div class="list-group list-group-sm">
                        @foreach (var field in Model.RequiredFieldsStatus)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center" 
                                 style="border-left: 4px solid @(field.Value ? "var(--success-color)" : "var(--danger-color)");">
                                <span>
                                    <i class="bi @(field.Value ? "bi-check-circle-fill" : "bi-x-circle-fill")" 
                                       style="color: @(field.Value ? "var(--success-color)" : "var(--danger-color)"); margin-right: 0.5rem;"></i>
                                    @field.Key
                                </span>
                                <span class="badge @(field.Value ? "bg-success" : "bg-danger")">
                                    @(field.Value ? "Present" : "Missing")
                                </span>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.AllRequiredFieldsPopulated)
                {
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-check-lg"></i> All required fields are present!
                    </div>
                }
            }
            else if (Model.IsValid)
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-lg"></i> Response is valid and well-formed.
                </div>
            }
        </div>
    </div>
}
